SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_TO=
PORT=3001

# Orígenes permitidos para CORS (separados por coma). En producción, los dominios reales.
ALLOWED_ORIGINS=http://localhost:5173,https://contalfa.com,https://www.contalfa.com

# Nº de proxies de confianza delante de la app (0 = sin proxy; 1 = un Nginx/CDN delante).
# Nunca poner un valor alto sin proxy real: habilitaría falsificar la IP y evadir el rate-limit.
TRUST_PROXY=0
