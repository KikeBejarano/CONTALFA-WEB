<?xml version="1.0" encoding="UTF-8"?>
<!--
  Configuración para el hosting Windows/IIS de ravatech (panel SolidCP).
  Vite copia este archivo de public/ a dist/, así que se despliega solo con cada build.

  Solo usa características base de IIS (sin URL Rewrite, que el hosting podría no tener):
  - Las rutas limpias funcionan porque el prerender emite ruta/index.html (documento
    por defecto) y el gemelo plano ruta.html.
  - Si el sitio devuelve "HTTP 500.19" al desplegar, el hosting tiene bloqueada alguna
    sección: eliminar el bloque <httpErrors> (es el bloqueado más habitual) y reintentar.
-->
<configuration>
  <system.webServer>
    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>

    <!-- URLs desconocidas: servir nuestro 404 prerenderizado (NotFound con noindex). -->
    <httpErrors errorMode="Custom" existingResponse="Replace">
      <remove statusCode="404" />
      <error statusCode="404" path="/404.html" responseMode="ExecuteURL" />
    </httpErrors>

    <staticContent>
      <!-- Formatos modernos que IIS antiguos no traen registrados (plan: imágenes WebP/AVIF). -->
      <remove fileExtension=".webp" />
      <mimeMap fileExtension=".webp" mimeType="image/webp" />
      <remove fileExtension=".avif" />
      <mimeMap fileExtension=".avif" mimeType="image/avif" />
      <!-- Caché corta por defecto; los bundles de /assets llevan hash en el nombre,
           pero el HTML debe revalidarse para que los deploys se vean al instante. -->
      <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="0.01:00:00" />
    </staticContent>
  </system.webServer>

  <!-- Assets con hash (js/css/img generados por Vite): inmutables, caché de 1 año. -->
  <location path="assets">
    <system.webServer>
      <staticContent>
        <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="365.00:00:00" />
      </staticContent>
    </system.webServer>
  </location>
</configuration>
