# URL pública del sitio (canonicals, OG, sitemap). Sin barra final.
VITE_SITE_URL=https://contalfa.com

# Origen del API en producción (p.ej. https://contalfa-api.onrender.com). Sin barra final.
# Vacío en dev: el proxy de Vite redirige /api a localhost:3001.
# OBLIGATORIA en el build de producción mientras el API viva en otro origen que la web.
VITE_API_URL=
